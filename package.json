{
  "name": "foundry-vox",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:web": "npm --prefix frontend run dev -- --host 127.0.0.1 --port 1420",
    "dev:backend": "uv run --project backend uvicorn app.main:app --host 127.0.0.1 --port 3456",
    "dev": "concurrently -k \"npm:dev:web\" \"npm:dev:backend\"",
    "build:web": "npm --prefix frontend run build",
    "build:sidecar": "sh ./scripts/build-sidecar.sh",
    "audit:preset-assets": "uv run --project backend python backend/verify_preset_assets.py",
    "audit:preset-assets:strict": "uv run --project backend python backend/verify_preset_assets.py --strict",
    "bench:engine": "uv run --project backend python backend/benchmark_mlx_rtf.py",
    "bench:engine:report": "uv run --project backend python backend/benchmark_mlx_rtf.py --skip-checks",
    "package:appstore": "./scripts/package_appstore.sh",
    "lint:web": "npm --prefix frontend run lint",
    "tauri:dev": "tauri dev",
    "tauri:build": "npm run build:web && npm run build:sidecar && tauri build",
    "tauri:build:appstore": "npm run build:web && npm run build:sidecar && tauri build --bundles app --config src-tauri/tauri.appstore.conf.json"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.7.1",
    "concurrently": "^9.1.2"
  }
}
